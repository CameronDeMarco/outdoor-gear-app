# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored — never commit real keys.

# ── Data source mode ──────────────────────────────────────────────────────────
# "mock"        Seed data only. No API keys needed. (default)
# "rainforest"  Amazon data via Rainforest API.
# "avantlink"   REI / Backcountry / Sierra via AvantLink feeds.
# "live"        Rainforest + AvantLink merged (full production).
DATA_SOURCE=mock

# ── Rainforest API (Amazon product data) ─────────────────────────────────────
# Sign up at: https://rainforestapi.com
# Free trial included. Key is on your dashboard under "API Key".
RAINFOREST_API_KEY=

# ── AvantLink (REI, Backcountry, Sierra affiliate feeds) ─────────────────────
# Sign up at: https://avantlink.com → Apply as Publisher
# After approval, find these under: Account → API Credentials
AVANTLINK_API_KEY=
AVANTLINK_WEBSITE_ID=

# ── AvantLink merchant IDs ────────────────────────────────────────────────────
# Once approved for each merchant program, find their IDs at:
# AvantLink dashboard → Merchants → [merchant name] → Merchant ID
# Then update MERCHANT_IDS in src/data/avantlink/index.ts with these values.
# REI merchant ID:         (find in dashboard)
# Backcountry merchant ID: (find in dashboard)
# Sierra merchant ID:      (find in dashboard)
